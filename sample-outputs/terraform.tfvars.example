# ============================================================================
# Terraform Variable Overrides
# ============================================================================
# Copy this file to terraform.tfvars and fill in your actual values.
# NEVER commit terraform.tfvars to version control if it contains secrets.
# ============================================================================

# Your Dynatrace Account UUID (found in Account Management)
# Example: "12345678-1234-1234-1234-123456789abc"
account_id = "YOUR_ACCOUNT_UUID"

# Your Dynatrace Environment ID (the ID portion of your environment URL)
# Example: "abc12345" from https://abc12345.live.dynatrace.com
environment_id = "YOUR_ENVIRONMENT_ID"

