    {
      "mode": "managed",
      "type": "dynatrace_iam_policy",
      "name": "admin_features",
      "provider": "provider[\"registry.terraform.io/dynatrace-oss/dynatrace\"]",
      "instances": [
        {
          "schema_version": 0,
          "attributes": {
            "account": "2eacb30f-4a0e-4435-b96b-7c67be0bcebc",
            "description": "Admin-level feature access without settings:objects:write. Use with Scoped Settings Write for bounded settings access.",
            "environment": null,
            "id": "d796c7d1-0620-4b94-9d6e-e51e1ae5e5c9#-#account#-#2eacb30f-4a0e-4435-b96b-7c67be0bcebc",
            "name": "Admin Features (No Settings Write)",
            "statement_query": "// Full automation admin (Standard User only has read + SIMPLE write)\nALLOW automation:workflows:read, automation:workflows:write, automation:workflows:run, automation:workflows:admin;\nALLOW automation:calendars:read, automation:calendars:write;\nALLOW automation:rules:read, automation:rules:write;\n\n// SLO management (Standard User only has read)\nALLOW slo:slos:read, slo:slos:write;\nALLOW slo:objective-templates:read;\n\n// Extensions management (Standard User only has read)\nALLOW extensions:definitions:read, extensions:definitions:write;\nALLOW extensions:configurations:read, extensions:configurations:write;\n\n// OpenPipeline configuration\nALLOW openpipeline:configurations:read, openpipeline:configurations:write;\n\n// App Engine management\nALLOW app-engine:apps:install, app-engine:apps:delete, app-engine:apps:run;\n",
            "tags": [
              "iam-config",
              "managed-by-terraform"
            ],
            "uuid": null
          },
          "sensitive_attributes": [],
          "identity_schema_version": 0,
          "private": "bnVsbA=="
        }
      ]
    },
    {
      "mode": "managed",
      "type": "dynatrace_iam_policy",
      "name": "scoped_data_read",
      "provider": "provider[\"registry.terraform.io/dynatrace-oss/dynatrace\"]",
      "instances": [
        {
          "schema_version": 0,
          "attributes": {
            "account": "2eacb30f-4a0e-4435-b96b-7c67be0bcebc",
            "description": "Grants read access to Grail data scoped by security_context prefix. Use bindParam for the scope.",
            "environment": null,
            "id": "6289bb58-de26-4ac7-86d6-0b05aab6acee#-#account#-#2eacb30f-4a0e-4435-b96b-7c67be0bcebc",
            "name": "Scoped Grail Data Read",
            "statement_query": "// Scoped read access to all Grail tables based on security_context\n// The security_context_prefix parameter is provided at binding time\n\n// Logs access\nALLOW storage:logs:read \n  WHERE storage:dt.security_context startsWith \"${bindParam:security_context_prefix}\";\n\n// Metrics access  \nALLOW storage:metrics:read \n  WHERE storage:dt.security_context startsWith \"${bindParam:security_context_prefix}\";\n\n// Spans/traces access\nALLOW storage:spans:read \n  WHERE storage:dt.security_context startsWith \"${bindParam:security_context_prefix}\";\n\n// Events access (excluding security events)\nALLOW storage:events:read \n  WHERE storage:dt.security_context startsWith \"${bindParam:security_context_prefix}\";\n\n// Business events access\nALLOW storage:bizevents:read \n  WHERE storage:dt.security_context startsWith \"${bindParam:security_context_prefix}\";\n\n// Entities access\nALLOW storage:entities:read \n  WHERE storage:dt.security_context startsWith \"${bindParam:security_context_prefix}\";\n\n// Smartscape access for topology\nALLOW storage:smartscape:read \n  WHERE storage:dt.security_context startsWith \"${bindParam:security_context_prefix}\";\n\n// User sessions and events (DEM data)\nALLOW storage:user.sessions:read \n  WHERE storage:dt.security_context startsWith \"${bindParam:security_context_prefix}\";\nALLOW storage:user.events:read \n  WHERE storage:dt.security_context startsWith \"${bindParam:security_context_prefix}\";\n",
            "tags": [
              "iam-config",
              "managed-by-terraform"
            ],
            "uuid": null
          },
          "sensitive_attributes": [],
          "identity_schema_version": 0,
          "private": "bnVsbA=="
        }
      ]
    },
    {
      "mode": "managed",
      "type": "dynatrace_iam_policy",
      "name": "scoped_settings_read",
      "provider": "provider[\"registry.terraform.io/dynatrace-oss/dynatrace\"]",
      "instances": [
        {
          "schema_version": 0,
          "attributes": {
            "account": "2eacb30f-4a0e-4435-b96b-7c67be0bcebc",
            "description": "Grants read access to settings scoped by security_context. Use bindParam for the scope.",
            "environment": null,
            "id": "53f33280-ccb5-40cf-b241-d9395a009cf4#-#account#-#2eacb30f-4a0e-4435-b96b-7c67be0bcebc",
            "name": "Scoped Settings Read",
            "statement_query": "// Read settings for entities with matching security_context\nALLOW settings:objects:read \n  WHERE settings:dt.security_context startsWith \"${bindParam:security_context_prefix}\";\nALLOW settings:schemas:read;\n",
            "tags": [
              "iam-config",
              "managed-by-terraform"
            ],
            "uuid": null
          },
          "sensitive_attributes": [],
          "identity_schema_version": 0,
          "private": "bnVsbA=="
        }
      ]
    },
    {
      "mode": "managed",
      "type": "dynatrace_iam_policy",
      "name": "scoped_settings_write",
      "provider": "provider[\"registry.terraform.io/dynatrace-oss/dynatrace\"]",
      "instances": [
        {
          "schema_version": 0,
          "attributes": {
            "account": "2eacb30f-4a0e-4435-b96b-7c67be0bcebc",
            "description": "Grants write access to settings scoped by security_context. For admins only.",
            "environment": null,
            "id": "71395d0e-999f-446a-8330-8086e992deef#-#account#-#2eacb30f-4a0e-4435-b96b-7c67be0bcebc",
            "name": "Scoped Settings Write",
            "statement_query": "// Read and write settings for entities with matching security_context\nALLOW settings:objects:read, settings:objects:write\n  WHERE settings:dt.security_context startsWith \"${bindParam:security_context_prefix}\";\nALLOW settings:schemas:read;\n",
            "tags": [
              "iam-config",
              "managed-by-terraform"
            ],
            "uuid": null
          },
          "sensitive_attributes": [],
          "identity_schema_version": 0,
          "private": "bnVsbA=="
        }
      ]
    },
    {
      "mode": "managed",
